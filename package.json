{
  "name": "nocodb-middleware",
  "version": "0.3.0",
  "description": "",
  "author": "Stephan Strittmatter",
  "private": true,
  "license": "MIT",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\" \"*.{md,json,yml}\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"test/**/*.ts\" \"*.{md,json,yml}\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "generate:openapi": "node scripts/generate-openapi.js",
    "changelog": "conventional-changelog -p angular -i CHANGELOG.md -s",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "mcp": "ts-node --esm scripts/mcp-server.ts"
  },
  "dependencies": {
    "@nestjs/cache-manager": "^3.1.3",
    "@nestjs/common": "^11.1.27",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.27",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.27",
    "@nestjs/swagger": "^11.4.4",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/auto-instrumentations-node": "^0.77.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.219.0",
    "@opentelemetry/resources": "^2.8.0",
    "@opentelemetry/sdk-node": "^0.218.0",
    "@opentelemetry/sdk-trace-base": "^2.7.1",
    "@opentelemetry/semantic-conventions": "^1.41.1",
    "axios": "^1.18.0",
    "axios-retry": "^4.5.0",
    "cache-manager": "^7.2.8",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "nest-winston": "^1.10.2",
    "nestjs-pino": "^4.6.1",
    "nocodb-sdk": "^0.301.3",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pino-http": "^11.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "sanitize-html": "^2.17.5",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@fission-ai/openspec": "^1.4.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@nestjs/cli": "^11.0.23",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.1.27",
    "@rollup/plugin-yaml": "^5.0.0",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^26.0.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/sanitize-html": "^2.16.1",
    "@types/supertest": "^7.2.0",
    "conventional-changelog-cli": "^5.0.0",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "globals": "^17.6.0",
    "jest": "^30.4.2",
    "js-yaml": "^5.0.0",
    "jsonwebtoken": "^9.0.3",
    "markdownlint-cli": "^0.49.0",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.4",
    "semver": "^7.8.4",
    "source-map-support": "^0.5.21",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "ts-loader": "^9.6.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.61.1",
    "vitepress": "^1.6.4"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s",
      "!main.ts",
      "!app.module.ts",
      "!auth/auth.module.ts",
      "!examples/examples.module.ts",
      "!health/health.module.ts",
      "!permissions/permissions.module.ts",
      "!tracing/telemetry.module.ts",
      "!**/tracing.ts",
      "!**/*.spec.ts",
      "!**/test-phase*.ts",
      "!**/debug-*.ts",
      "!**/delete-*.ts",
      "!**/inspect-*.ts",
      "!**/investigate-*.ts",
      "!**/test-*.ts",
      "!config/cors.config.ts",
      "!nocodb/middleware/rate-limit.middleware.ts"
    ],
    "coverageDirectory": "../coverage",
    "coverageReporters": [
      "text",
      "lcov",
      "json-summary"
    ],
    "testEnvironment": "node"
  },
  "overrides": {
    "lodash": "^4.18.1",
    "vite": "^6.4.2",
    "esbuild": "^0.25.12"
  }
}
