# NocoDB Configuration
NOCODB_API_URL=http://localhost:8080
NOCODB_API_TOKEN=your_api_token_here

# Base ID is required for Meta API v3 operations (create tables/columns)
# Get this from your NocoDB workspace URL or API
NOCODB_BASE_ID=your_base_id_here

# Optional: Project ID for legacy SDK operations
NOCODB_PROJECT_ID=optional_project_id

# Optional: Prefix for all managed tables (e.g., 'app_' -> 'app_users', 'app_roles')
# Leave empty for no prefix
NOCODB_TABLE_PREFIX=

# Optional: Name of the NocoDB table used by ExampleRepository (default: 'examples')
# The repository will look up the table ID by this name at startup via the Meta API.
NOCODB_EXAMPLE_TABLE_NAME=examples

# JWT Configuration
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=1d
