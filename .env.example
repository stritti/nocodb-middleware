# NocoDB Configuration
NOCODB_API_URL=http://localhost:8080
NOCODB_API_TOKEN=your_api_token_here

# Base ID is required for Meta API v3 operations (create tables/columns)
# Get this from your NocoDB workspace URL or API
NOCODB_BASE_ID=your_base_id_here

# Optional: Prefix for all managed tables (e.g., 'app_' -> 'app_users', 'app_roles')
# Leave empty for no prefix
NOCODB_TABLE_PREFIX=

# Logging Configuration
# Directory to store log files (absolute or relative path)
# Default: ./logs
LOG_DIR=logs

# JWT Configuration
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=1d

# Optional: existing username to promote to admin on first bootstrap
# No default admin user/password is auto-created anymore
NOCODB_BOOTSTRAP_ADMIN_USERNAME=

# Initial admin bootstrap token (required for /bootstrap/admin)
BOOTSTRAP_ADMIN_TOKEN=

# OpenTelemetry Configuration
# Set to 'true' to enable distributed tracing (default: disabled)
OTEL_ENABLED=false

# Service name reported in traces (default: 'nocodb-middleware')
OTEL_SERVICE_NAME=nocodb-middleware

# OTLP collector endpoint for trace export.
# When set, spans are forwarded to this URL via OTLP/HTTP.
# When unset (and OTEL_ENABLED=true), spans are printed to stdout (useful for development).
# Example: http://localhost:4318/v1/traces
OTEL_EXPORTER_OTLP_ENDPOINT=

# Server
PORT=3000

# CORS – comma-separated list of allowed origins
# Example: https://app.example.com,https://admin.example.com
CORS_ORIGINS=http://localhost:3000

# Logging
# Log level: trace | debug | info | warn | error | fatal (default: debug in dev, info in prod)
LOG_LEVEL=info
