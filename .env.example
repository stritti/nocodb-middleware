# NocoDB Configuration
NOCODB_API_URL=http://localhost:8080
NOCODB_API_TOKEN=your_api_token_here

# Base ID is required for Meta API v2 operations (create tables/columns)
# Get this from your NocoDB workspace URL or API
NOCODB_BASE_ID=your_base_id_here

# Optional: Prefix for all managed tables (e.g., 'app_' -> 'app_users', 'app_roles')
# Leave empty for no prefix
NOCODB_TABLE_PREFIX=

# Logging Configuration
# Directory to store log files (absolute or relative path)
# Default: ./logs
LOG_DIR=logs

# JWT Configuration
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=1d

# Optional: existing username to promote to admin on first bootstrap
# No default admin user/password is auto-created anymore
NOCODB_BOOTSTRAP_ADMIN_USERNAME=

# Initial admin bootstrap token (required for /bootstrap/admin)
BOOTSTRAP_ADMIN_TOKEN=
